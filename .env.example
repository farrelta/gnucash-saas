# ============================================
# GnuCash SaaS — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Database (Azure MySQL) ---
# Format: mysql+pymysql://user:password@host:port/database
DATABASE_URL=mysql+pymysql://gnucash_admin:your-password@your-server.mysql.database.azure.com:3306/gnucash_saas

# --- JWT Authentication ---
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string
JWT_EXPIRATION_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# --- User Data Storage ---
# Path on host where user GnuCash files are stored
USER_DATA_PATH=/opt/gnucash-data

# --- Rate Limiting ---
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute

# --- Idle Session Cleanup ---
IDLE_TIMEOUT_MINUTES=60

# --- Let's Encrypt ---
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com
